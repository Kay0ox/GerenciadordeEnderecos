<!DOCTYPE html>
<html lang="pt-br" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Gerenciador de Endereços</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" href="#">Gerenciador de Endereços</a>
            <div class="ms-auto d-flex align-items-center gap-3">
                <button id="toggleTheme" class="btn btn-sm btn-outline-secondary">
                    Modo Claro
                </button>
                @if (User.Identity!.IsAuthenticated)
                {
                    <span class="nav-user">@User.Identity.Name</span>
                    <a href="/Conta/Logout" class="btn btn-outline-light btn-sm">Sair</a>
                }
            </div>
        </div>
    </nav>

    <main class="container mt-4">
        @RenderBody()
    </main>

    <footer class="text-center mt-5 py-3">
        <small>Gerenciador de Endereços &copy; 2026</small>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const toggle = document.getElementById('toggleTheme');
        const html = document.documentElement;

        const saved = localStorage.getItem('theme') || 'dark';
        html.setAttribute('data-theme', saved);
        toggle.textContent = saved === 'dark' ? 'Modo Claro' : 'Modo Escuro';

        toggle.addEventListener('click', () => {
        const current = html.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
        toggle.textContent = next === 'dark' ? 'Modo Claro' : 'Modo Escuro';
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>